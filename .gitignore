## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ww][Pp]7[Cc]onfig/
[Aa][Nn][Dd][Rr][Oo][Ii][Dd]/

# MSTest test Results
[Tt]est[Rr]esults/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent-conformance.exe.config

# Build Results of External Libraries
*.lib
*.pdb
*.dll
*.ide

# StyleCop
StyleCopReport.xml

# Files for VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Core
wwwroot/lib/

# Web.config
# Web.config should be included in source control, but it might contain secrets.
# If you are using User Secrets, then Web.config should not contain secrets.
# If you are not using User Secrets, then consider encrypting secrets in Web.config.
# Web.config

# Rider
.idea/
*.sln.iml

# Docker
.dockerignore
# Dockerfile should be included in source control.

# End of standard .NET .gitignore
